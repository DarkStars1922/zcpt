APP_NAME=综测平台后端
ENVIRONMENT=local

SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_SECONDS=7200
REFRESH_TOKEN_EXPIRE_SECONDS=604800

# Local SQLite mode
DATABASE_URL=sqlite:///./platform.db

# MySQL mode example
# DATABASE_URL=mysql+pymysql://root:root@127.0.0.1:3306/zcpt?charset=utf8mb4

SQL_ECHO=false
AUTO_CREATE_TABLES=false
DB_POOL_SIZE=8
DB_MAX_OVERFLOW=8
DB_POOL_RECYCLE_SECONDS=1800
DB_POOL_TIMEOUT_SECONDS=30

REDIS_ENABLED=true
REDIS_URL=redis://127.0.0.1:6379/0

CELERY_TASK_ALWAYS_EAGER=false
CELERY_TASK_EAGER_PROPAGATES=true
CELERY_RESULT_EXPIRES_SECONDS=86400
CELERY_WORKER_PREFETCH_MULTIPLIER=1
CELERY_TASK_ACKS_LATE=true
CELERY_TASK_REJECT_ON_WORKER_LOST=true

UPLOAD_DIR=./uploads
EXPORT_DIR=./exports
UPLOAD_MAX_FILE_SIZE=26214400

EMAIL_PROVIDER=mock
EMAIL_DEFAULT_FROM=noreply@zcpt.local
EMAIL_MOCK_SUCCESS=true

AI_AUDIT_PROVIDER=paddleocr
AI_AUDIT_FALLBACK_TO_MANUAL=true

# Standalone image authenticity extension. Not wired into application/review flow.
# Recommended external service pipeline:
# C2PA/c2patool provenance + SynthID/watermark + TruFor tampering localization
# + UniversalFakeDetect/AI-GenBench style AI-generated image detector.
IMAGE_AUTHENTICITY_PROVIDER=hybrid
IMAGE_AUTHENTICITY_API_URL=
IMAGE_AUTHENTICITY_API_KEY=
IMAGE_AUTHENTICITY_MODEL=c2pa+synthid+trufor+universal_fake_detect
IMAGE_AUTHENTICITY_TIMEOUT_SECONDS=30
IMAGE_AUTHENTICITY_C2PATOOL_PATH=c2patool

FILE_ANALYSIS_ENABLED=true
PADDLE_MODEL_SOURCE=BOS
PADDLE_MODEL_DIR=./models/paddleocr
PADDLEOCR_DEVICE=cpu
PADDLEOCR_USE_DOC_ORIENTATION_CLASSIFY=true
PADDLEOCR_USE_TEXTLINE_ORIENTATION=true
PADDLEOCR_TEXT_DETECTION_MODEL_NAME=PP-OCRv5_mobile_det
PADDLEOCR_TEXT_DETECTION_MODEL_DIR=
PADDLEOCR_TEXT_RECOGNITION_MODEL_NAME=PP-OCRv5_mobile_rec
PADDLEOCR_TEXT_RECOGNITION_MODEL_DIR=
PADDLEOCR_LAYOUT_DETECTION_MODEL_NAME=PP-DocLayout-S
PADDLEOCR_LAYOUT_DETECTION_MODEL_DIR=
PADDLEOCR_CPU_THREADS=4
PADDLEOCR_ENABLE_MKLDNN=false
PADDLEOCR_SEAL_SCORE_THRESHOLD=0.4

DEFAULT_TERM=2025-2026-1

# Personal report LLM evaluation, OpenAI-compatible chat/completions endpoint.
# Leave URL or key empty to keep the report evaluation placeholder.
EVALUATION_LLM_API_URL=
EVALUATION_LLM_API_KEY=
# Example:
# EVALUATION_LLM_API_URL=https://api.example.com/v1/chat/completions
# EVALUATION_LLM_API_KEY=sk-xxxxxxxx
EVALUATION_LLM_MODEL=gpt-4o-mini
EVALUATION_LLM_TIMEOUT_SECONDS=20
EVALUATION_LLM_TEMPERATURE=0.7
EVALUATION_LLM_MAX_TOKENS=320
